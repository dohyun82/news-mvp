# NewsBot environment

# OpenAI API key for summarization
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4

# Slack bot token and channel
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_CHANNEL_ID=your-slack-channel-id

# Article content fetch/extract settings
ARTICLE_FETCH_ENABLED=true
ARTICLE_FETCH_TIMEOUT_SECONDS=5
ARTICLE_TEXT_MAX_CHARS=4000

# Real data (Naver Search API)
REALDATA_ENABLED=true
NAVER_API_CLIENT_ID=your-naver-client-id
NAVER_API_CLIENT_SECRET=your-naver-client-secret
NAVER_TIMEOUT_MS=5000
NAVER_SORT=sim
NAVER_DELAY_MS=300
NAVER_LOG_EACH_ITEM=true

# Datadog API credentials
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com
